[10.413832, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mI can help you test S3 error\u001b[1Chandling,\u001b[1Cbut\u001b[1CI\u001b[1Cwant\u001b[1Cto\u001b[1Cconfirm\u001b[1Cfirst:\u001b[1Crunning\u001b[1Cthis\u001b[1Ccommand\u001b[1Cwill\u001b[1Cchange\u001b[1Cthe\u001b[1CACL\u001b[1Cof\u001b[1C\"demo-bucket\"\u001b[1Cto\u001b[1C\u001b[38;5;153mpublic-read\u001b[39m,\u001b[1Cwhich\u001b[1Cmakes\u001b[1Call\u001b[1Cobjects\u001b[1Cin\u001b[1Cthat\r\u001b[2C\u001b[1Bbucket\u001b[1Cpublicly\u001b[1Creadable\u001b[1Cby\u001b[1Canyone\u001b[1Con\u001b[1Cthe\u001b[1Cinternet.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[10.592245, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Is this a test/demo bucket in a non-production environment, and do you want me to proceed with making it public-read?                                                          \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[11.592874, "o", "\u001b]0;⠂ Test S3 bucket ACL error handling\u0007\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Once you confirm, I'll run the command and we can see what error handling responses we get.                                                                                    \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m✢\u001b[39m \u001b[38;5;174mEvap\u001b[38;5;216mora\u001b[38;5;174mting… \u001b[39m                                                                                                                                                                  \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l\u001b]0;✳ Test S3 bucket ACL error handling\u0007\u001b[?2026h\u001b[2D\u001b[3B\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[1A\r\u001b[4A\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[39m❯ \u001b[7m \r\u001b[2B\u001b[27m  \u001b[38;5;147m⏵⏵ accept edits on\u001b[38;5;246m (shift+tab to cycle)\r\u001b[1B\u001b[39m                                                                                                                                                                                 \r\u001b[1B                                                                                                                                                                                 \r\u001b[1A\u001b[2C\u001b[3A\u001b[?2026l\u001b[<u\u001b[>1u\u001b[>4;2m\u001b]0;⠂ Test S3 bucket ACL error handling\u0007\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231myes\u001b[39m                                                                                                                                                                            \r\u001b[1B\u001b[49m   \r\u001b[1B\u001b[38;5;174m·\u001b[39m \u001b[38;5;180mWorking…\u001b[38;5;174m \u001b[39m                                                                                                                                                                      \r\u001b[1B\u001b[38;5;246m  ⎿  Tip: Name your conversa\u001b[1Cions with /rename to find them easily in /resume later\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────"]
